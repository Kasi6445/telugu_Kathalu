# Telugu Katalu — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env to git.

# ── Gemini / Google AI Studio ─────────────────────────────────────────────────
# Used as FALLBACK when GCP_PROJECT_ID is not set.
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_YOUR_KEY_HERE

# Alias recognised by some Google client libraries (optional, same value as above)
GOOGLE_API_KEY=

# Safety guard: if GCP_PROJECT_ID is NOT set, make_client() raises RuntimeError
# unless this is explicitly set to true. Prevents accidental AI Studio billing.
# Values: true | false (default: false)
ALLOW_AI_STUDIO=false

# ── Vertex AI (GCP) — PRIMARY when set ───────────────────────────────────────
# When GCP_PROJECT_ID is present, ALL Gemini calls route to Vertex AI and
# bill against your GCP project credits instead of per-API-key quota.
#
# Setup (one-time):
#   gcloud auth application-default login
#   gcloud config set project YOUR_PROJECT_ID
#   gcloud services enable aiplatform.googleapis.com texttospeech.googleapis.com
#
# Get your project ID: https://console.cloud.google.com/home/dashboard
GCP_PROJECT_ID=your-gcp-project-id

# Region for Vertex AI calls.
# ⚠️  Keep us-central1: gemini-2.5-pro, gemini-2.5-flash-preview-tts, and
#     Imagen are NOT available in asia-south1 as of 2026.
GCP_LOCATION=us-central1

# ── Other API keys ────────────────────────────────────────────────────────────
GROQ_API_KEY=
LEONARDO_API_KEY=
SARVAM_API_KEY=
